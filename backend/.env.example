# ─── MongoDB ────────────────────────────────────────────────────────────────
# Connection URI for your MongoDB instance
# Local example : mongodb://localhost:27017
# Atlas example : mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net
MONGO_URI=mongodb://localhost:27017

# Name of the MongoDB database to use
DB_NAME=odessey

# ─── Ola Maps ────────────────────────────────────────────────────────────────
# API key from https://maps.olacabs.com/
# Used for: text-search, reverse-geocode, autocomplete, geocode
OLA_MAPS_API_KEY=your_ola_maps_api_key_here
